# Everything is optional — the site runs with zero env vars.

# The-Odds-API key for pre-game win probabilities on today's matches
# (the-odds-api.com free tier). Without it, games render without odds chips.
ODDS_API_KEY=

# JSON overrides for the pool config in lib/config.js (redeploy to apply):
# POOL_ROSTERS=[{"name":"Player","teams":["Spain","Japan"]},...]
# POOL_FORECAST={"Spain":{"t":"Spain","st":"CH","gw":3,"gd":0,"uw":2},...}
POOL_ROSTERS=
POOL_FORECAST=
