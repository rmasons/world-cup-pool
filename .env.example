# Upstash Redis (auto-populated by the Vercel Marketplace integration)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: The-Odds-API key for pre-game win probabilities on today's matches.
# Without it, games simply render without odds chips.
ODDS_API_KEY=

# Optional: protects the cron GET endpoint (Vercel sends it automatically when set)
CRON_SECRET=

# Optional: override the write-gate pool code (defaults to WC26FUN)
POOL_CODE=
